{
  "template_id": "electrician_trust_v1",
  "template_version": 1,
  "sections": ["hero", "services", "why_us", "testimonials", "cta_footer"],
  "image_slots": {
    "hero.background": {
      "role": "background",
      "aspect": "16:9",
      "minPx": { "w": 1920, "h": 1080 },
      "displayPx": { "w": 1920, "h": 1080 },
      "safeZone": "center",
      "label": "Hero background",
      "required": false
    },
    "services.items[].image": {
      "role": "card_thumb",
      "aspect": "4:3",
      "minPx": { "w": 800, "h": 600 },
      "displayPx": { "w": 400, "h": 300 },
      "maxCount": 8,
      "label": "Service photo",
      "required": false
    },
    "testimonials.items[].avatar": {
      "role": "avatar",
      "aspect": "1:1",
      "minPx": { "w": 200, "h": 200 },
      "displayPx": { "w": 80, "h": 80 },
      "safeZone": "face-center",
      "label": "Customer photo",
      "required": false
    }
  },
  "schema": {
    "hero": {
      "headline": { "type": "string", "maxLength": 60 },
      "subtext": { "type": "string", "maxLength": 140 },
      "cta_text": { "type": "string", "maxLength": 25 }
    },
    "services": {
      "section_title": { "type": "string", "maxLength": 40 },
      "items": {
        "maxItems": 8,
        "item": {
          "title": { "type": "string", "maxLength": 40 },
          "desc": { "type": "string", "maxLength": 120 }
        }
      }
    },
    "why_us": {
      "section_title": { "type": "string", "maxLength": 40 },
      "points": {
        "maxItems": 5,
        "item": { "type": "string", "maxLength": 80 }
      }
    },
    "testimonials": {
      "section_title": { "type": "string", "maxLength": 40 },
      "items": {
        "maxItems": 6,
        "item": {
          "name": { "type": "string", "maxLength": 30 },
          "quote": { "type": "string", "maxLength": 160 }
        }
      }
    },
    "cta_footer": {
      "headline": { "type": "string", "maxLength": 70 },
      "cta_text": { "type": "string", "maxLength": 25 }
    }
  }
}
